+bool PasteboardService::IsDisallowDistributed()
+{
+    pid_t uid = IPCSkeleton::GetCallingUid();
+    if (uid == DEVICE_COLLABORATION_UID) {
+        PASTEBOARD_HILOGI(PASTEBOARD_MODULE_SERVICE, "uid from device collaboration");
