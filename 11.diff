+bool PasteboardService::IsNeedLink(PasteData &data)
+{
+    for (const auto &record : data.AllRecords()) {
+        if (record == nullptr) {
+            continue;
+        }
+        auto uri = record->GetConvertUri();
+        if (uri.empty()) {
+            continue;
+        }
+        if (uri.find("networkid=") != std::string::npos) {
+            return true;
+        }
+    }
+    return false;
+}
