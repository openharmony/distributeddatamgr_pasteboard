+constexpr uint64_t MAIN_DISPLAY_ID = 0;
+constexpr const char *USER_SWITCH_OLD_ID = "oldId";
+constexpr const char *PACKAGE_REMOVED_USER_ID = "userId";
+
+enum class UserContextSource : int32_t {
+    CALLER = 0,
+    MAIN_DISPLAY,
+    FOREGROUND,
+    USER_SWITCHED_NEW,
+    USER_SWITCHED_OLD,
+    USER_STOPPING,
+    PACKAGE_REMOVED,
