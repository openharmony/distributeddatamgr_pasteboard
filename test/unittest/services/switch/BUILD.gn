import("//build/test.gni")
import("//foundation/distributeddatamgr/pasteboard/pasteboard.gni")

module_output_path = "pasteboard/pasteboard"

ohos_unittest("PasteboardSwitchTest") {
  module_out_path = module_output_path
  
  cflags = [ "-fno-access-control" ]  
  include_dirs = [
    "${pasteboard_framework_path}/include",
    "${pasteboard_root_path}/services/switch/include",
    "${pasteboard_root_path}/adapter/test/mock/data_share",
    "${pasteboard_root_path}/framework/framework/include/device",
    "${pasteboard_root_path}/utils/native/include",
  ]
  
  sources = [
    "${pasteboard_framework_path}/common/pasteboard_common_utils.cpp",
    "${pasteboard_root_path}/adapter/test/mock/data_share/datashare_delegate.cpp",
    "${pasteboard_root_path}/services/switch/pasteboard_switch.cpp",
    "pasteboard_switch_test.cpp",
  ]
  
  external_deps = [
    "c_utils:utils",
    "googletest:gmock",
    "hilog:libhilog",
    "ipc:ipc_single",
  ]
}

group("unittest") {
  testonly = true
  
  deps = [
    ":PasteboardSwitchTest",
  ]
}
